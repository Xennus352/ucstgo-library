// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------
// 1. USER & BETTER-AUTH MODULE (Unified)
// ----------------------------------------------------

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(true)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Your Custom University Library Fields
  studentId String? @unique
  role      Role    @default(STUDENT)
  banned    Boolean @default(false)
  faculty   String?
  phone     String?

  // Better-Auth Technical Relations
  sessions     Session[]
  accounts     Account[]
  createdBooks Book[]    @relation("LecturerCreatedBooks")

  // Library Application Relations
  borrowRecords  BorrowRecord[]
  reservations   Reservation[]
  readingHistory ReadingHistory[]
  bookmarks      Bookmark[]

  // Explicitly named notification relations (Duplicates removed ✅)
  notificationsReceived Notification[]     @relation("NotificationRecipient")
  notificationsSent     Notification[]     @relation("NotificationSender")
  notificationReads     NotificationRead[]
  pushSubscriptions     PushSubscription[]

  @@index([email])
  @@index([studentId])
  @@index([role])
  @@map("user")
}

enum Role {
  ADMIN
  LIBRARIAN
  STUDENT
  LECTURER
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Allows credentials login alongside OAuth
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ----------------------------------------------------
// 2. CORE BOOK CATALOG MODULE
// ----------------------------------------------------

model Book {
  id              String  @id @default(uuid())
  isbn            String  @unique
  title           String
  description     String?
  publisher       String?
  publicationYear Int?
  language        String  @default("English")
  coverImage      String?
  donate          String?

  categoryId String
  authorId   String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author   Author   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  copies       BookCopy[]
  ebook        Ebook?
  reservations Reservation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("LecturerCreatedBooks", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isbn])
  @@index([title])
  @@index([categoryId])
  @@index([authorId])
  @@index([createdById])
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  books Book[]

  @@index([name])
}

model Author {
  id   String @id @default(uuid())
  name String @unique

  books Book[]

  @@index([name])
}

// ----------------------------------------------------
// 3. PHYSICAL LIBRARY SYSTEM (Circulation)
// ----------------------------------------------------

model BookCopy {
  id            String     @id @default(uuid())
  barcode       String     @unique
  shelfLocation String?
  status        CopyStatus @default(AVAILABLE)
  createdAt     DateTime   @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookId String

  borrowRecords BorrowRecord[]

  @@index([bookId])
  @@index([barcode])
  @@index([status])
}

enum CopyStatus {
  AVAILABLE
  BORROWED
  LOST
  DAMAGED
}

model BorrowRecord {
  id         String       @id @default(uuid())
  borrowDate DateTime     @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     BorrowStatus @default(BORROWED)

  userId String
  copyId String

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  copy BookCopy @relation(fields: [copyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([copyId])
  @@index([status])
  @@index([dueDate])
  @@index([userId, status])
}

enum BorrowStatus {
  BORROWED
  RETURNED
  OVERDUE
}

model Reservation {
  id         String            @id @default(uuid())
  reservedAt DateTime          @default(now())
  expiresAt  DateTime?
  status     ReservationStatus @default(ACTIVE)

  userId String
  bookId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([bookId])
  @@index([status])
  @@index([expiresAt])
}

enum ReservationStatus {
  ACTIVE // user is waiting in queue
  FULFILLED // book was issued to user
  CANCELLED // user cancelled manually
  EXPIRED // system auto-expired reservation
}

// ----------------------------------------------------
// 4. DIGITAL LIBRARY (E-Books)
// ----------------------------------------------------

model Ebook {
  id         String          @id @default(uuid())
  filePath   String
  fileSize   Int?
  format     EbookFormat     @default(PDF)
  accessType EbookAccessType @default(OPEN)
  semester   Semester?

  bookId String @unique
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  readingHistory ReadingHistory[]
  bookmarks      Bookmark[]

  @@index([bookId])
  @@index([format])
}

enum Semester {
  Y1_SEM1
  Y1_SEM2
  Y2_SEM1
  Y2_SEM2
  Y3_SEM1
  Y3_SEM2
  Y4_SEM1
  Y4_SEM2

  MASTER
}

enum EbookFormat {
  PDF
  EPUB
  DOCX
}

enum EbookAccessType {
  OPEN
  STUDENT_ONLY
  LECTURER_ONLY
  ADMIN_ONLY
}

model ReadingHistory {
  id          String   @id @default(uuid())
  lastPage    Int      @default(1)
  progress    Float    @default(0)
  readingTime Int      @default(0)
  updatedAt   DateTime @updatedAt

  userId  String
  ebookId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ebook Ebook @relation(fields: [ebookId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, ebookId])
  @@index([userId])
  @@index([ebookId])
}

model Bookmark {
  id         String   @id @default(uuid())
  pageNumber Int
  note       String?
  createdAt  DateTime @default(now())

  userId  String
  ebookId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ebook Ebook @relation(fields: [ebookId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([ebookId])
}

// ----------------------------------------------------
// 5. NOTIFICATIONS
// ----------------------------------------------------

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation("NotificationRecipient", fields: [userId], references: [id])

  senderId String?
  sender   User?   @relation("NotificationSender", fields: [senderId], references: [id])

  reads NotificationRead[]

  @@index([userId])
}

model NotificationRead {
  id String @id @default(uuid())

  notificationId String
  userId         String

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
}

model PushSubscription {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  keys     Json

  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------
//  SYSTEM CONFIGURATION MODULE
// ----------------------------------------------------

model SystemSetting {
  key         String   @id // Unique identifier like 'about_p1', 'vision', 'footer_phone'
  value       String   @db.Text // Large text storage for paragraphs or data configurations
  description String? // Optional context string for the Admin Panel UI
  updatedAt   DateTime @updatedAt

  @@map("system_setting")
}
